{
  "name": "agrippa",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "biome check . && tsc -b && bun scripts/check-deps.ts",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc -b",
    "test": "bun test",
    "db:migrate": "bun packages/db/src/cli/migrate.ts",
    "db:seed": "bun packages/db/src/cli/seed.ts",
    "templates:seed": "bun scripts/seed-templates.ts",
    "templates:validate": "bun scripts/validate-templates.ts",
    "build": "bun --filter '@agrippa/web' build",
    "dev": "bun --filter '*' dev"
  },
  "devDependencies": {
    "@agrippa/db": "workspace:*",
    "@agrippa/orchestration": "workspace:*",
    "@biomejs/biome": "^2.0.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/bun": "^1.2.0",
    "playwright": "^1.61.1",
    "typescript": "^7.0.2"
  }
}
