# Agrippa self-hosted configuration (docs/design/08-deployment.md)
# Copy to infra/env/.env and fill in the secrets.

# ── Required secrets ───────────────────────────────────────────────────────────
# Encrypts stored credentials (git tokens, MCP auth). 32 bytes base64.
# LOSING THIS KEY ORPHANS ALL STORED CREDENTIALS — back it up.
#   openssl rand -base64 32
AGRIPPA_SECRET_KEY=

# Session signing secret for better-auth.
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# ── First admin (one-time bootstrap) ───────────────────────────────────────────
# Self-registration is closed (invite-only). Create the first org_admin out-of-
# band once, then unset or leave these (the script is idempotent on email):
#   bun --env-file=infra/env/.env apps/api/src/cli/bootstrap-admin.ts
# Password is hashed with better-auth's hashPassword; the account signs in at
# the login page. Not read by the running api/worker — bootstrap-only.
AGRIPPA_BOOTSTRAP_EMAIL=
AGRIPPA_BOOTSTRAP_PASSWORD=

# ── Model provider ─────────────────────────────────────────────────────────────
# Required for real runs (executor: claude-agent-sdk). Leave empty and set
# AGRIPPA_EXECUTOR=fake for a token-free demo deployment.
ANTHROPIC_API_KEY=
AGRIPPA_EXECUTOR=claude-agent-sdk

# ── Deployment ─────────────────────────────────────────────────────────────────
# Public URL of the instance (links in PRs/emails, auth callbacks).
AGRIPPA_BASE_URL=http://localhost:3000
AGRIPPA_PORT=3000
POSTGRES_PASSWORD=change-me
WORKER_SLOTS=2
WORKER_REPLICAS=1
# Image tag when pulling instead of building.
AGRIPPA_VERSION=latest

# Optional: closer Debian apt mirror for the worker image build, for hosts where
# deb.debian.org is slow/blocked (e.g. CN). Leave empty elsewhere.
#   APT_MIRROR=https://mirrors.aliyun.com
APT_MIRROR=
