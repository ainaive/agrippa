# Agrippa VM (systemd) configuration — /etc/agrippa/agrippa.env
# Rendered by infra/vm/install.sh on first install (placeholders substituted);
# both agrippa-api.service and agrippa-worker.service load this file.
# See docs/design/08-deployment.md and docs/manual/en/06-operations.md.

# ── Stack ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://agrippa:__DB_PASSWORD__@127.0.0.1:5432/agrippa
# Redis is optional: remove to fall back to DB polling for SSE.
REDIS_URL=redis://127.0.0.1:6379

# ── Required secrets ───────────────────────────────────────────────────────────
# Encrypts stored credentials (git tokens, MCP auth). 32 bytes base64.
# LOSING THIS KEY ORPHANS ALL STORED CREDENTIALS — back it up.
AGRIPPA_SECRET_KEY=__SECRET_KEY__

# Session signing secret for better-auth.
BETTER_AUTH_SECRET=__AUTH_SECRET__

# ── Model provider ─────────────────────────────────────────────────────────────
# Required for real runs (executor: claude-agent-sdk). Leave empty and set
# AGRIPPA_EXECUTOR=fake for a token-free demo deployment.
ANTHROPIC_API_KEY=
AGRIPPA_EXECUTOR=claude-agent-sdk

# ── Deployment ─────────────────────────────────────────────────────────────────
# Public URL of the instance (links in PRs/emails, auth callbacks).
AGRIPPA_BASE_URL=http://localhost:3000
PORT=3000
WORKER_SLOTS=2

# ── Paths (match the layout install.sh creates) ────────────────────────────────
WORKSPACE_ROOT=/var/lib/agrippa/runs
ARTIFACT_STORAGE_ROOT=/var/lib/agrippa/artifacts
AGRIPPA_TEMPLATES_DIR=/opt/agrippa/templates
# Set → the API serves the built SPA (same-origin, no separate web server).
AGRIPPA_WEB_DIST=/opt/agrippa/apps/web/dist

# ── Optional toggles ───────────────────────────────────────────────────────────
# AGRIPPA_MIGRATE_ON_BOOT=0    # disable automatic migrate+seed on API boot
# AGRIPPA_KEEP_WORKSPACES=1    # keep finished run workspaces for debugging
