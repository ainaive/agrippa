# Agrippa behind nginx — minimal reverse-proxy example.
# TLS is operator-owned (docs/design/08-deployment.md): add your certificates
# or certbot configuration on top of this.

server {
    listen 80;
    server_name agrippa.example.com;

    # SSE — run event streams break if the proxy buffers them (events arrive
    # in bursts instead of live). Keep buffering OFF on this route.
    location ~ ^/api/v1/runs/.+/events$ {
        proxy_pass http://127.0.0.1:3000;
        proxy_buffering off;
        proxy_cache off;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_read_timeout 1h;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Everything else: API + the SPA the API serves (same-origin, no CORS).
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
